{
  "version": 2,
  "installCommand": "npm install",
  "outputDirectory": "public",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 120,
      "includeFiles": "server.js"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/[...path].js" },
    { "src": "/health", "dest": "/api/index.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
